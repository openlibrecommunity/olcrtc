# Provider and room
OLCRTC_PROVIDER=jazz-visual
OLCRTC_ROOM_ID=any

# Optional fixed key. Leave empty to let entrypoint generate and persist one in
# ${OLCRTC_STATE_DIR}/key.hex on first start.
OLCRTC_KEY=

# Runtime behavior
OLCRTC_DNS=1.1.1.1:53
OLCRTC_DUO=false
OLCRTC_DEBUG=true
OLCRTC_DATA_DIR=/usr/share/olcrtc

# Host paths mounted into the container
OLCRTC_STATE_DIR=./data/docker/server-state
OLCRTC_MEDIA_DIR=./data/docker/media

# Optional visual mode paths inside the container.
# Put your carrier file on the host under ${OLCRTC_MEDIA_DIR}.
OLCRTC_VISUAL_BACKGROUND=/mnt/olcrtc-media/bg.yuv
OLCRTC_VISUAL_DUMP=/var/lib/olcrtc/visual-dump
